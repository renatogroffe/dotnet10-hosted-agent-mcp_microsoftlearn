# Azure AI Foundry project endpoint
# Format: https://<hub-name>.services.ai.azure.com/api/projects/<project-name>
# Find it in: Azure AI Foundry portal → your project → Overview → "Project endpoint"
FOUNDRY_PROJECT_ENDPOINT=

# Model deployment name in your Foundry project (defaults to "gpt-4o" if not set)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.5

# Capture prompt and completion content on GenAI spans.
# Off by default in OpenTelemetry GenAI semantic conventions; set true to include message content in traces.
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true